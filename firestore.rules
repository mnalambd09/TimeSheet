rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, enum: ["worker", "admin"])
    //   - createdAt: timestamp (required)
    //
    // Collection: timesheets
    // Document ID: {entryId}
    // Fields:
    //   - workerId: string (required)
    //   - workerName: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - startTime: string (required, HH:mm)
    //   - endTime: string (required, HH:mm)
    //   - totalHours: number (required)
    //   - notes: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // The first email address below is the "Bootstrap Admin". 
      // Change this email when setting up for a new client.
      let bootstrapAdminEmail = "MNALAMBD09@gmail.com";
      
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == bootstrapAdminEmail
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['worker', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidTimesheet(data) {
      return data.keys().hasAll(['workerId', 'workerName', 'date', 'startTime', 'endTime', 'totalHours', 'createdAt']) &&
             data.workerId is string &&
             data.workerName is string &&
             data.date is string && data.date.matches("^[0-9]{4}-[0-9]{2}-[0-9]{2}$") &&
             data.startTime is string && data.startTime.matches("^[0-9]{2}:[0-9]{2}$") &&
             data.endTime is string && data.endTime.matches("^[0-9]{2}:[0-9]{2}$") &&
             data.totalHours is number &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data));
      allow delete: if isAdmin();
    }

    match /timesheets/{entryId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.workerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTimesheet(request.resource.data) && (request.resource.data.workerId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isAuthenticated() && resource.data.workerId == request.auth.uid && isValidTimesheet(request.resource.data));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.workerId == request.auth.uid);
    }
  }
}
